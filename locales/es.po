msgid "What is my IP address?"
msgstr "Cual es mi direccion IP?"

msgid "Find your public IP address instantly. Look up geolocation, ASN, organization, and proxy/VPN/Tor detection for any IP address."
msgstr "Encuentra tu direccion IP publica al instante. Consulta la geolocalizacion, ASN, organizacion y deteccion de proxy/VPN/Tor para cualquier direccion IP."

msgid "Search IP address"
msgstr "Buscar direccion IP"

msgid "Type to search IP data"
msgstr "Escribe para buscar datos de IP"

