msgid "What is my IP address?"
msgstr "Apa alamat IP saya?"

msgid "Find your public IP address instantly. Look up geolocation, ASN, organization, and proxy/VPN/Tor detection for any IP address."
msgstr "Temukan alamat IP publik Anda secara instan. Cari geolokasi, ASN, organisasi, dan deteksi proxy/VPN/Tor untuk alamat IP apa pun."

msgid "Search IP address"
msgstr "Cari alamat IP"

msgid "Type to search IP data"
msgstr "Ketik untuk mencari data IP"

msgid "ASN"
msgstr "ASN"

msgid "Org"
msgstr "Org"

