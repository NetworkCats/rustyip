msgid "What is my IP address?"
msgstr "Quelle est mon adresse IP ?"

msgid "Find your public IP address instantly. Look up geolocation, ASN, organization, and proxy/VPN/Tor detection for any IP address."
msgstr "Trouvez votre adresse IP publique instantanement. Recherchez la geolocalisation, l'ASN, l'organisation et la detection de proxy/VPN/Tor pour n'importe quelle adresse IP."

msgid "Search IP address"
msgstr "Rechercher une adresse IP"

msgid "Type to search IP data"
msgstr "Saisissez pour rechercher des donnees IP"

msgid "ASN"
msgstr "ASN"

msgid "Org"
msgstr "Org"

