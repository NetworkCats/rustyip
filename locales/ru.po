msgid "What is my IP address?"
msgstr "Какой у меня IP-адрес?"

msgid "Find your public IP address instantly. Look up geolocation, ASN, organization, and proxy/VPN/Tor detection for any IP address."
msgstr "Мгновенно узнайте свой публичный IP-адрес. Определите геолокацию, ASN, организацию, а также обнаружение прокси/VPN/Tor для любого IP-адреса."

msgid "Search IP address"
msgstr "Поиск IP-адреса"

msgid "Type to search IP data"
msgstr "Введите для поиска данных IP"

