global
    log stderr local0 err
    maxconn 4096
    # Performance tuning (sized for 1 vCPU / 1 GB RAM)
    tune.bufsize 16384
    tune.maxrewrite 1024
    tune.http.maxhdr 101
    tune.comp.maxlevel 1
    # TLS configuration optimized for Cloudflare Origin CA ECC certificates
    ssl-default-bind-curves prime256v1:X25519:secp384r1
    ssl-default-bind-ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-RSA-AES256-GCM-SHA384
    ssl-default-bind-ciphersuites TLS_AES_128_GCM_SHA256:TLS_AES_256_GCM_SHA384:TLS_CHACHA20_POLY1305_SHA256
    ssl-default-bind-options prefer-client-ciphers ssl-min-ver TLSv1.2 no-tls-tickets

defaults
    log     global
    mode    http
    option  httplog
    option  dontlog-normal
    option  http-keep-alive
    maxconn 4096
    timeout connect 5s
    timeout client  30s
    timeout server  30s
    timeout http-request 10s
    timeout http-keep-alive 60s
    timeout queue 30s

frontend http_in
    bind *:80

    # Gzip compression
    compression algo gzip
    compression type text/html text/plain application/json text/css

    # Access to port 80 is restricted to Cloudflare IPs at the firewall level
    # All requests reaching HAProxy come from Cloudflare; no additional ACL validation is required.

{% if ipv4_domain %}
    # Identify IPv4-only domain traffic by Host header
    acl is_ipv4_domain hdr(host) -f /usr/local/etc/haproxy/ipv4_domain.lst

{% endif %}
    # HAProxy's own forwardfor is not enabled; real IP is set explicitly below via CF-Connecting-IP
{% if ipv4_domain %}
    # Main domain: standard headers
    http-request set-header X-Forwarded-For %[req.hdr(CF-Connecting-IP)] if !is_ipv4_domain
    http-request set-header X-Real-IP      %[req.hdr(CF-Connecting-IP)] if !is_ipv4_domain
    # IPv4-only domain: separate header to prevent confusion with the main domain
    http-request set-header X-IPv4-Client-IP %[req.hdr(CF-Connecting-IP)] if is_ipv4_domain
    http-request del-header X-Forwarded-For if is_ipv4_domain
    http-request del-header X-Real-IP       if is_ipv4_domain
{% else %}
    # Overwrite standard headers directly with the real IP forcibly added by Cloudflare
    http-request set-header X-Forwarded-For %[req.hdr(CF-Connecting-IP)]
    http-request set-header X-Real-IP      %[req.hdr(CF-Connecting-IP)]
{% endif %}

    # Rate limiting: tiered based on global request rate
    # Track per-IP request rate (per minute)
    stick-table type string len 45 size 100k expire 1m store http_req_rate(1m)
    http-request track-sc0 req.hdr(CF-Connecting-IP)
    # Track global request rate (per second)
    http-request track-sc1 str(global) table global_rate_tracking

    # Tier 3: global >= 300 RPS -> limit each IP to 15 RPM
    http-request deny deny_status 429 if { sc_http_req_rate(1,global_rate_tracking) ge 300 } { sc_http_req_rate(0) gt 15 }
    # Tier 2: global >= 200 RPS -> limit each IP to 30 RPM
    http-request deny deny_status 429 if { sc_http_req_rate(1,global_rate_tracking) ge 200 } { sc_http_req_rate(0) gt 30 }
    # Tier 1: default -> limit each IP to 60 RPM
    http-request deny deny_status 429 if { sc_http_req_rate(0) gt 60 }

    # Block /health from external access
    acl is_health path /health
    http-request deny deny_status 403 if is_health

    default_backend app

frontend https_in
{% if ipv4_domain %}
    bind *:443 ssl crt /etc/haproxy/certs/origin.pem crt /etc/haproxy/certs-ipv4/origin.pem alpn h2,http/1.1 strict-sni
{% else %}
    bind *:443 ssl crt /etc/haproxy/certs/origin.pem alpn h2,http/1.1 strict-sni
{% endif %}

    # Gzip compression
    compression algo gzip
    compression type text/html text/plain application/json text/css

    # Access to port 443 is restricted to Cloudflare IPs at the firewall level
    # All requests reaching HAProxy come from Cloudflare; no additional ACL validation is required.

{% if ipv4_domain %}
    # Identify IPv4-only domain traffic by Host header
    acl is_ipv4_domain hdr(host) -f /usr/local/etc/haproxy/ipv4_domain.lst

{% endif %}
    # HAProxy's own forwardfor is not enabled; real IP is set explicitly below via CF-Connecting-IP
{% if ipv4_domain %}
    # Main domain: standard headers
    http-request set-header X-Forwarded-For %[req.hdr(CF-Connecting-IP)] if !is_ipv4_domain
    http-request set-header X-Real-IP      %[req.hdr(CF-Connecting-IP)] if !is_ipv4_domain
    # IPv4-only domain: separate header to prevent confusion with the main domain
    http-request set-header X-IPv4-Client-IP %[req.hdr(CF-Connecting-IP)] if is_ipv4_domain
    http-request del-header X-Forwarded-For if is_ipv4_domain
    http-request del-header X-Real-IP       if is_ipv4_domain
{% else %}
    # Overwrite standard headers directly with the real IP forcibly added by Cloudflare
    http-request set-header X-Forwarded-For %[req.hdr(CF-Connecting-IP)]
    http-request set-header X-Real-IP      %[req.hdr(CF-Connecting-IP)]
{% endif %}

    # Rate limiting uses the shared stick-table from http_in frontend
    http-request track-sc0 req.hdr(CF-Connecting-IP) table http_in
    # Track global request rate (per second)
    http-request track-sc1 str(global) table global_rate_tracking

    # Tier 3: global >= 300 RPS -> limit each IP to 15 RPM
    http-request deny deny_status 429 if { sc_http_req_rate(1,global_rate_tracking) ge 300 } { sc_http_req_rate(0,http_in) gt 15 }
    # Tier 2: global >= 200 RPS -> limit each IP to 30 RPM
    http-request deny deny_status 429 if { sc_http_req_rate(1,global_rate_tracking) ge 200 } { sc_http_req_rate(0,http_in) gt 30 }
    # Tier 1: default -> limit each IP to 60 RPM
    http-request deny deny_status 429 if { sc_http_req_rate(0,http_in) gt 60 }

    # Block /health from external access
    acl is_health path /health
    http-request deny deny_status 403 if is_health

    default_backend app

backend global_rate_tracking
    stick-table type string len 6 size 1 expire 10m store http_req_rate(1s)

frontend stats_internal
    bind 127.0.0.1:9000
    mode http
    stats enable
    stats uri /stats
    stats refresh 2s

resolvers docker_dns
    nameserver dns1 127.0.0.11:53
    resolve_retries 3
    timeout resolve 1s
    timeout retry 1s
    hold valid 10s
    hold nx 5s
    hold obsolete 30s

backend app
    balance roundrobin
    option httpchk GET /health
    http-check expect status 200

    # Blue-green backends: only the active color is enabled
    # init-addr none allows HAProxy to start when the inactive container does not exist
    server blue app-blue:3000 resolvers docker_dns check inter 2s fall 3 rise 2 init-addr none {{ 'disabled' if active_color == 'green' else '' }}
    server green app-green:3000 resolvers docker_dns check inter 2s fall 3 rise 2 init-addr none {{ 'disabled' if active_color == 'blue' else '' }}
