services:
  haproxy:
    image: haproxy:3.3.4-alpine3.23
    container_name: rustyip-haproxy
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./haproxy/haproxy.cfg:/usr/local/etc/haproxy/haproxy.cfg:ro
      - ./haproxy/ipv4_domain.lst:/usr/local/etc/haproxy/ipv4_domain.lst:ro
      - ./haproxy/certs:/etc/haproxy/certs:ro
{% if ipv4_domain %}
      - ./haproxy/certs-ipv4:/etc/haproxy/certs-ipv4:ro
{% endif %}
    restart: unless-stopped
    ulimits:
      nofile:
        soft: 32768
        hard: 32768
    sysctls:
      net.core.somaxconn: "4096"
      net.ipv4.tcp_tw_reuse: "1"
    networks:
      - internal

  app-blue:
    image: {{ app_image }}
    container_name: rustyip-app-blue
    env_file: .env
    volumes:
      - db_data_blue:/data
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:3000/health || exit 1"]
      interval: 5s
      timeout: 3s
      retries: 3
      start_period: 5s
    restart: unless-stopped
    ulimits:
      nofile:
        soft: 32768
        hard: 32768
    networks:
      - internal

  app-green:
    image: {{ app_image }}
    container_name: rustyip-app-green
    env_file: .env
    volumes:
      - db_data_green:/data
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:3000/health || exit 1"]
      interval: 5s
      timeout: 3s
      retries: 3
      start_period: 5s
    restart: unless-stopped
    ulimits:
      nofile:
        soft: 32768
        hard: 32768
    networks:
      - internal

volumes:
  db_data_blue:
  db_data_green:

networks:
  internal:
    driver: bridge
